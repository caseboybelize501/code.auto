# JARVIS - llama.cpp Configuration
# Copy this to .env and modify as needed

# LLM Provider Settings
CODE_AUTO_LLM_PROVIDER=llama-cpp
CODE_AUTO_LOCAL_LLM_ENABLED=true
CODE_AUTO_LOCAL_LLM_URL=http://localhost:8080
CODE_AUTO_LOCAL_LLM_MODEL=local-model
CODE_AUTO_LOCAL_LLM_CONTEXT=8192

# Default Model Path (modify to use your preferred model)
CODE_AUTO_DEFAULT_MODEL_PATH=D:\models\qwen2.5-coder-7b.gguf

# Server Settings
LLAMA_SERVER_HOST=localhost
LLAMA_SERVER_PORT=8080
LLAMA_SERVER_CONTEXT_LENGTH=8192
LLAMA_SERVER_BATCH_SIZE=512
LLAMA_SERVER_THREADS=8

# GPU Offloading (set to number of layers to offload, or 0 for CPU only)
LLAMA_SERVER_GPU_LAYERS=99

# Model Aliases (comma-separated name:path pairs)
# Format: alias1:path1,alias2:path2
LLAMA_MODEL_ALIASES=qwen2.5-coder-7b:D:\models\qwen2.5-coder-7b.gguf,qwen3-coder-30b-q4:D:\models\qwen3-coder-30b-q4.gguf,mistral-7b:D:\AI\models\mistral-7b-instruct-v0.2.Q4_K_M.gguf
