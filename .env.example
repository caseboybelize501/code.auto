# JARVIS Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Selection
# =============================================================================
# Options: "llama-cpp" (local, free), "openai" (commercial), "anthropic" (commercial)
# Default: llama-cpp (uses your local offline API)

CODE_AUTO_LLM_PROVIDER=llama-cpp

# =============================================================================
# Local llama.cpp Configuration (OWNER USE - NO API KEY NEEDED)
# =============================================================================
# Your offline llama.cpp server settings

CODE_AUTO_LOCAL_LLM_ENABLED=true
CODE_AUTO_LOCAL_LLM_URL=http://localhost:8080
CODE_AUTO_LOCAL_LLM_MODEL=local-model
CODE_AUTO_LOCAL_LLM_CONTEXT=8192

# =============================================================================
# Commercial API Keys (FOR CUSTOMER DEPLOYMENTS)
# =============================================================================
# Only needed if deploying for customers who want cloud-based AI

# OpenAI API Key (get from https://platform.openai.com/api-keys)
# CODE_AUTO_OPENAI_API_KEY=sk-your-openai-api-key-here
# CODE_AUTO_OPENAI_MODEL=gpt-4o-mini

# Anthropic API Key (get from https://console.anthropic.com/settings/keys)
# CODE_AUTO_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# CODE_AUTO_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# Database Configuration (OPTIONAL - falls back to in-memory)
# =============================================================================

# ChromaDB (Vector Memory)
# CODE_AUTO_CHROMA_HOST=localhost
# CODE_AUTO_CHROMA_PORT=8000
# CODE_AUTO_CHROMA_COLLECTION=code_auto_memory

# Neo4j (Graph Database - Optional)
# CODE_AUTO_NEO4J_URI=bolt://localhost:7687
# CODE_AUTO_NEO4J_USER=neo4j
# CODE_AUTO_NEO4J_PASSWORD=password

# Redis (Cache - Optional)
# CODE_AUTO_REDIS_HOST=localhost
# CODE_AUTO_REDIS_PORT=6379

# =============================================================================
# Build & Deployment Configuration
# =============================================================================

# Timeouts (in seconds)
# CODE_AUTO_BUILD_TIMEOUT=300
# CODE_AUTO_TEST_TIMEOUT=600
# CODE_AUTO_DEPLOYMENT_TIMEOUT=120

# Docker Registry (for deployment)
# CODE_AUTO_DOCKER_REGISTRY=localhost:5000

# =============================================================================
# Working Directories
# =============================================================================

# CODE_AUTO_WORK_DIR=./workspace
# CODE_AUTO_LOGS_DIR=./logs
